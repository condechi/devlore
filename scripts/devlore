#!/usr/bin/env bash
# devlore — your AI conversations, compiled into a self-checking knowledge base.
# This dispatcher operates on the KB it lives in (self-locating, multi-KB safe).
#
# The whole body lives in main() called as `main "$@"; exit $?` on one line, so
# bash parses the entire script into memory before executing. `devlore update`
# rewrites this very file in place; without the wrap, bash would resume reading
# the now-overwritten file at a stale byte offset and emit spurious syntax errors
# after a size-changing self-update.
main() {
set -uo pipefail

# The caller's shell directory, captured BEFORE PY() runs scripts via
# `uv run --directory "$KB"` (which starts Python inside the KB). add/remove
# resolve a relative path argument like `.` against this, so it means the
# directory you ran devlore FROM — not the KB (utils.resolve_invocation_path).
export DEVLORE_INVOCATION_CWD="$PWD"

# Resolve symlinks so KB is the real KB root even when devlore is invoked through
# a symlink on PATH (install.sh links ~/.local/bin/devlore → <KB>/scripts/devlore).
# The bare PATH symlink is the one AMBIGUOUS way in: mark it so add/remove can
# route to the owning KB (kb_resolve.py). A full-path launcher means "this KB",
# so the marker is explicitly cleared (it may linger in the environment).
src="${BASH_SOURCE[0]:-$0}"
if [ -h "$src" ]; then
  export DEVLORE_VIA_PATH_SYMLINK=1
else
  unset DEVLORE_VIA_PATH_SYMLINK
fi
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$dir/$src" ;; esac
done
KB="$(cd -P "$(dirname "$src")/.." >/dev/null 2>&1 && pwd)"
PY() { uv run --directory "$KB" python "$KB/scripts/$1" "${@:2}"; }

# Installed KBs and the dist carry a VERSION file; a source checkout falls back
# to the constant in build_dist.py.
VER="$(cat "$KB/VERSION" 2>/dev/null || sed -n 's/^VERSION = "\(.*\)"$/\1/p' "$KB/scripts/build_dist.py" 2>/dev/null)"
VER="${VER:-dev}"

cmd="${1:-help}"
case "$cmd" in
  add)        PY add_codebase.py "${@:2}" ;;
  ask)        PY query.py "${@:2}" ;;
  compile)    PY compile.py "${@:2}" ;;
  verify)     PY verify.py "${@:2}" ;;
  backfill)   PY ingest_all_context.py "${@:2}" ;;
  docs)       PY ingest_doc.py "${@:2}" && PY compile.py ;;
  recheck)    PY recheck.py "${@:2}" ;;
  remove)     PY remove_codebase.py "${@:2}" ;;
  update)     PY update_kb.py "${@:2}" ;;
  obsidian)   PY obsidian_setup.py "${@:2}" ;;
  init)       PY init_kb.py "${@:2}" ;;
  version|--version|-V)
    echo "devlore v$VER  (KB: $KB)"
    ;;
  status)
    echo "devlore v$VER — knowledge base: $KB"
    total=0; parts=""
    for d in concepts connections qa mocs; do
      c=$(ls "$KB/knowledge/$d"/*.md 2>/dev/null | wc -l | tr -d ' ')
      total=$((total + c)); parts="$parts$c $d, "
    done
    echo "  articles:     $total  (${parts%, })"
    echo "                knowledge/index.md is the catalog"
    dl=$(ls "$KB"/daily/2*.md 2>/dev/null | wc -l | tr -d ' ')
    if [ "$dl" -gt 0 ]; then
      first=$(basename "$(ls "$KB"/daily/2*.md | head -1)" .md)
      last=$(basename "$(ls "$KB"/daily/2*.md | tail -1)" .md)
      echo "  dailies:      $dl daily log(s), $first → $last"
    else
      echo "  dailies:      none yet"
    fi
    mk=$(ls "$KB"/scripts/flush-marker-*.json 2>/dev/null | wc -l | tr -d ' ')
    echo "  sessions:     $mk conversation(s) captured"
    q=$(ls "$KB"/quarantine/*.md 2>/dev/null | wc -l | tr -d ' ')
    [ "$q" -gt 0 ] && echo "  quarantine:   $q conversation(s) awaiting review"
    echo "  capture roots (live conversation capture is on for):"
    grep -v '^\s*#\|^\s*$' "$KB/scripts/capture-roots" 2>/dev/null | sed 's/^/    /' \
      || echo "    (none — run: devlore add <codebase>)"
    cr=$(grep -v '^\s*#\|^\s*$' "$KB/scripts/code-roots" 2>/dev/null | tr '\n' ' ')
    [ -n "$cr" ] && echo "  code roots:   $cr"
    ledger=$(python3 -c "import json; d = json.load(open('$KB/scripts/state.json')); print('%.2f USD total compile/query spend, %d question(s) answered' % (d.get('total_cost', 0), d.get('query_count', 0)))" 2>/dev/null)
    [ -n "$ledger" ] && echo "  ledger:       $ledger"
    echo "  recent commits:"
    git -C "$KB" log --oneline -3 2>/dev/null | sed 's/^/    /'
    PY staleness.py | head -3
    ;;
  help|--help|-h|*)
    cat <<EOF
devlore v$VER — your AI conversations, compiled into a self-checking knowledge base
KB: $KB

The loop: every Claude Code or Codex session in an opted-in codebase is captured into
daily/ logs; \`compile\` distills them into wiki articles under knowledge/; the
article index is injected into each new session, so your assistant starts
already knowing your project's lore.

Getting started
  devlore add <codebase>      opt a repo in: live capture from now on, plus an
                              offer to backfill its past conversations and
                              ingest its markdown docs (git-aware scan of the
                              root + first-level dirs; --full-recursive for
                              the whole tree)
  devlore status              what this KB holds: articles, dailies, captured
                              sessions, capture roots, spend, staleness
  devlore ask "question"      cited answer from the KB (index-guided retrieval;
                              --dev adds live file:line code pointers,
                              --file-back saves the answer as a qa/ article)

Day to day
  devlore compile             compile pending daily logs into wiki articles
  devlore docs <file|dir>     ingest hand-written markdown, then compile (a dir
                              scans root + first-level subdirs, git-aware;
                              --full-recursive scans the whole tree)
  devlore backfill            batch-ingest past conversations (shows a plan and
                              cost estimate first; add --yes to execute)

Trust & upkeep
  devlore verify              hallucination + staleness gates (Tier-1/2)
  devlore recheck             refresh needs-reverification marks after edits
  devlore remove <codebase>   stop capturing a codebase — knowledge stays; the
                              code link is kept so existing articles remain
                              verified (--full disconnects that too)
  devlore update              refresh this KB's machinery from the latest
                              release — knowledge/, daily/, and your config are
                              never touched
  devlore version             print the installed devlore version

Obsidian (optional)
  devlore obsidian            add/refresh the optional Obsidian layer in THIS KB
                              — the side-panel plugin + vault config, so you can
                              open the KB as a vault (ingest/compile/ask/verify/
                              status from the palette, ribbon, right-click). Safe
                              to re-run; prints the one-time activation steps. Use
                              it if you skipped Obsidian at install time.

Elsewhere
  devlore init <dir> [...]    bootstrap ANOTHER knowledge base in a new
                              directory (each KB is independent)

Multiple KBs: the bare \`devlore\` on PATH routes add/remove to the KB that
OWNS the path (most-specific match across ~/.claude/kb-dirs; it asks when
ambiguous, --kb <kb-path> overrides). A launcher invoked by full path
(<kb>/scripts/devlore …) always operates on its own KB.

Safe by default: backfill and compile show the plan and the bill before
spending anything, and update never touches what makes the KB yours.

A note on doc ingestion: every accepted file is compiled by the LLM — real
cost. devlore filters out gitignored, vendored, and third-party markdown
(git-aware scan + deny-list), but those filters are best-effort: review the
preview before confirming, especially with --full-recursive.
EOF
    ;;
esac
}
main "$@"; exit $?
